HOST=0.0.0.0
PORT=3001
NODE_ENV=development

# ClickUp API — Obtenir sur : ClickUp > Profil > Apps > API Token
CLICKUP_API_TOKEN=pk_VOTRE_TOKEN_ICI

# ClickUp List IDs — Trouver dans l'URL de chaque liste ClickUp
# ex: app.clickup.com/xxxxx/v/li/XXXXXXXXX
CLICKUP_LIST_ID_ACTIONS=VOTRE_LIST_ID_ACTIONS
CLICKUP_LIST_ID_CONSUMABLES=VOTRE_LIST_ID_CONSUMABLES
CLICKUP_LIST_ID_ANOMALIES=VOTRE_LIST_ID_ANOMALIES
